---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, checkoutUrl } from "../config/site";
---
<Layout
  title="تم! حمّل عيّنتك المجانية الآن — مستقل الذكاء الاصطناعي"
  description="شكراً للاشتراك. هذه صفحة تحميل قائمة المراجعة المجانية بصيغة PDF."
  noIndex
>
  <Header />
  <main id="main" class="py-20">
    <div class="container-page max-w-3xl">
      <div class="card md:p-10">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full grid place-items-center bg-accent-500/15 border border-accent-500/40 text-accent-500">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span class="badge !bg-accent-500/10 !border-accent-500/30 !text-accent-500">تم الاشتراك بنجاح</span>
        </div>
        <h1 class="mt-4 text-3xl md:text-5xl font-black text-ink-50 text-balance">
          عيّنتك جاهزة. حمّلها الآن.
        </h1>
        <p class="mt-3 text-ink-200 text-lg leading-relaxed">
          أرسلنا الرابط إلى بريدك أيضاً. لكن لا تنتظر — افتحها الليلة، وحدّد خدمة واحدة من السبع لتبدأ بها هذا الأسبوع.
        </p>

        <a
          href={site.leadMagnetUrl}
          download
          class="btn-primary text-base mt-6"
          data-cta="thanks-download"
        >
          حمّل قائمة المراجعة (PDF)
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
        </a>

        <hr class="my-10 border-white/5" />

        <h2 class="text-2xl md:text-3xl font-black text-ink-50">قبل أن تذهب — عرض إطلاق محدود.</h2>
        <p class="mt-3 text-ink-200 leading-relaxed">
          لأنك من القرّاء الأوائل، يمكنك الحصول على الكتاب الكامل (٤٢ صفحة) + كل الهدايا
          بسعر إطلاق <span class="text-brand-300 font-bold">{site.prices.launch}$ بدلاً من {site.prices.full}$</span> — العرض ينتهي قريباً.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a href={checkoutUrl()} class="btn-primary" data-cta="thanks-upsell">
            احصل على الكتاب كاملاً — {site.prices.launch}$
          </a>
          <a href="/" class="btn-secondary">العودة للصفحة الرئيسية</a>
        </div>
        <p class="mt-4 text-xs text-ink-400">ضمان استرجاع ٧ أيام · دفع آمن · تحديثات مجانية مدى الحياة</p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  if (window.fbq) try { window.fbq("track", "CompleteRegistration"); } catch (_) {}
  if (window.ttq) try { window.ttq.track("CompleteRegistration"); } catch (_) {}
  if (window.gtag) try { window.gtag("event", "sign_up"); } catch (_) {}
</script>
