---
const forYou = [
  "عربي بين 18 و 40 سنة.",
  "عندك ٢ إلى ٤ ساعات يومياً للالتزام.",
  "إنجليزيتك B1 أو أعلى (تستطيع كتابة جملة).",
  "عندك لاب توب وإنترنت.",
  "جاد فعلاً، لا \"أحب أعرف فقط\".",
  "مستعد تستثمر ٢٥–١٠٠$ شهرياً في الأدوات.",
];
const notForYou = [
  "تريد \"ربحاً سهلاً بلا عمل\".",
  "لا تستطيع تخصيص ساعتين يومياً.",
  "تتوقع 5000$ في الشهر الأول.",
  "ترفض دفع أي اشتراك للأدوات.",
  "تكره الإنجليزية وترفض تحسينها.",
];
---
<section class="py-16 md:py-24">
  <div class="container-page grid md:grid-cols-2 gap-6">
    <div class="card border-accent-500/30">
      <span class="badge !bg-accent-500/10 !border-accent-500/30 !text-accent-500">هذا الكتاب لك إذا</span>
      <ul class="mt-4">
        {forYou.map((t) => <li class="check-row text-ink-100">{t}</li>)}
      </ul>
    </div>
    <div class="card border-red-500/20">
      <span class="badge !bg-red-500/10 !border-red-500/25 !text-red-300">هذا الكتاب ليس لك إذا</span>
      <ul class="mt-4">
        {notForYou.map((t) => <li class="x-row text-ink-100">{t}</li>)}
      </ul>
      <p class="mt-4 text-ink-400 text-sm">كن صادقاً مع نفسك. لو لم ينطبق عليك الوصف الأول، لا تشتري.</p>
    </div>
  </div>
</section>
