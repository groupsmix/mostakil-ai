---
const items = [
  "فتحت حساب Upwork، قدّمت 30 بروبوزال، ولم يردّ عليك أحد.",
  "سمعت عن \"العمل الحر مع AI\" في كل مكان، لكنك لا تعرف من أين تبدأ.",
  "تستخدم ChatGPT لكنك تشعر أنه \"بسيط\" ولا يكفي للبيع الجدي.",
  "تخاف أن إنجليزيتك ليست كافية للتنافس مع الأمريكي والفلبيني.",
  "مللت من فيديوهات يوتيوب التحفيزية بلا خطوات تنفيذية.",
  "تريد دخلاً جانبياً (أو رئيسياً) من الإنترنت بدون مخاطرة كبيرة.",
  "تشعر أن \"موجة AI\" قد تفوتك إذا لم تتحرك الآن.",
];
---
<section class="py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="badge">المشكلة</span>
      <h2 class="mt-4 text-3xl md:text-5xl font-black text-ink-50 text-balance">
        هل تجد نفسك في إحدى هذه الحالات؟
      </h2>
      <p class="mt-3 text-ink-300 text-lg">إن انطبق عليك ٣ منها أو أكثر، فالكتاب مكتوب لك.</p>
    </div>
    <ul class="mt-10 grid md:grid-cols-2 gap-x-10 gap-y-1 text-ink-100 text-lg">
      {items.map((t) => <li class="check-row">{t}</li>)}
    </ul>
  </div>
</section>
