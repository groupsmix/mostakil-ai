---
const reviews = [
  { q: "اقتنيت ٥ كورسات قبله، ولا واحد كان عملياً مثله. في الأسبوع الثاني، حصلت على أول وظيفة بـ 120$.", a: "خالد م.", c: "الرياض" },
  { q: "الفصل عن البروبوزال وحده يستحق ثمن الكتاب ١٠ أضعاف. غيّر طريقتي تماماً.", a: "أحمد ك.", c: "القاهرة" },
  { q: "أنا مصمّمة، طبّقت الفصل ٤ عن Midjourney. خلال ٦٠ يوماً وصلت 800$/شهر.", a: "ندى ش.", c: "تونس" },
  { q: "أحب فيه إنه ما يبيعك أحلاماً. يعطيك أرقاماً واقعية ويقول لك متى راح تفشل قبل ما تفشل.", a: "يوسف ع.", c: "الدوحة" },
];
---
<section class="py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="badge">آراء القرّاء الأوائل</span>
      <h2 class="mt-4 text-3xl md:text-5xl font-black text-ink-50 text-balance">
        ما يقوله المشترون السابقون.
      </h2>
    </div>
    <div class="mt-10 grid md:grid-cols-2 gap-4">
      {reviews.map((r) => (
        <figure class="card">
          <div class="flex gap-1 text-brand-400" aria-label="5/5">
            {Array.from({length:5}).map(() => (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4.5L6 21l1.5-7.5L2 9h7z"/></svg>
            ))}
          </div>
          <blockquote class="mt-3 text-ink-100 text-lg leading-relaxed">"{r.q}"</blockquote>
          <figcaption class="mt-4 text-sm text-ink-300">
            <span class="font-bold text-ink-100">{r.a}</span> — {r.c}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
