---
const bonuses = [
  { t: "قوالب رسائل جاهزة", v: "29$", d: "8 قوالب احترافية للتواصل مع العملاء، طلب مراجعات، رفع الأسعار، وإغلاق صفقات شهرية." },
  { t: "نصوص بروبوزال جاهزة", v: "39$", d: "7 نصوص بروبوزال (واحد لكل خدمة) بمعدّل ردّ يصل إلى 30%، قابلة للتخصيص في دقيقة." },
  { t: "قائمة الأدوات 2026", v: "19$", d: "كل أداة بسعرها الفعلي 2026، البديل المجاني، ومتى تشترك ومتى لا." },
  { t: "خارطة 90 يوماً (PDF)", v: "29$", d: "تقويم أسبوعي تنفيذي مع KPIs قابلة للقياس وحدود واقعية للتقدّم." },
  { t: "تحديثات سنوية مجانية", v: "$$$", d: "السوق يتغيّر. النسخ المستقبلية مجانية للمشترين الأوائل، إلى الأبد." },
];
---
<section id="bonuses" class="py-16 md:py-24 border-y border-white/5 bg-[radial-gradient(ellipse_at_top,rgba(249,106,16,0.08),transparent_55%)]">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="badge">٥ هدايا مجانية</span>
      <h2 class="mt-4 text-3xl md:text-5xl font-black text-ink-50 text-balance">
        قيمة إضافية بـ <span class="text-brand-400">115$+</span> — مجاناً مع الكتاب.
      </h2>
      <p class="mt-3 text-ink-300 text-lg">للإطلاق فقط. تُحذف هذه الهدايا بعد أول 100 نسخة.</p>
    </div>
    <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {bonuses.map((b, i) => (
        <article class="card relative overflow-hidden">
          <div class="absolute -top-2 -left-2 text-7xl font-black text-white/[0.04] select-none">{(i+1).toString().padStart(2,"0")}</div>
          <div class="relative">
            <span class="badge !bg-brand-500/15 !border-brand-400/40 !text-brand-200">قيمة {b.v}</span>
            <h3 class="mt-3 text-xl font-extrabold text-ink-50">{b.t}</h3>
            <p class="mt-2 text-ink-300 text-sm leading-relaxed">{b.d}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
