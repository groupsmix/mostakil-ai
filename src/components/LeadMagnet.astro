---
import { site } from "../config/site";
---
<section id="lead" class="py-20 md:py-28 relative overflow-hidden">
  <div class="absolute inset-0 grid-bg pointer-events-none" aria-hidden="true"></div>
  <div class="container-page relative">
    <div class="card md:p-10 max-w-4xl mx-auto border-brand-400/30 bg-gradient-to-br from-brand-500/10 via-transparent to-accent-500/10">
      <div class="grid md:grid-cols-12 gap-8 items-center">
        <div class="md:col-span-7">
          <span class="badge !bg-brand-500/15 !border-brand-400/40 !text-brand-200">عيّنة مجانية · لا بطاقة مطلوبة</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-black text-ink-50 text-balance">
            خذ "قائمة المراجعة" المجانية الآن.
          </h2>
          <p class="mt-3 text-ink-200 text-lg leading-relaxed">
            ٧ خدمات AI تستطيع بيعها على Upwork، نطاقات أسعار 2026، الأداة الأساسية لكل خدمة، وخطوة واحدة محورية لتبدأ بها اليوم. ٦ صفحات PDF عربية.
          </p>
          <ul class="mt-5">
            <li class="check-row text-ink-100">٧ خدمات بنطاق أسعار حقيقي.</li>
            <li class="check-row text-ink-100">الأدوات الأساسية + متى المجانية تكفيك.</li>
            <li class="check-row text-ink-100">تحديثات أسبوعية في بريدك (٧ إيميلات).</li>
          </ul>

          <form
            id="lead-form"
            class="mt-7 flex flex-col sm:flex-row gap-3"
            novalidate
          >
            <label class="sr-only" for="lead-email">بريدك الإلكتروني</label>
            <input
              id="lead-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="بريدك الإلكتروني"
              class="flex-1 px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-brand-400 focus:bg-white/10 outline-none text-ink-50 placeholder-ink-400"
            />
            <button type="submit" class="btn-primary whitespace-nowrap" data-cta="leadmagnet-submit">
              أرسل لي العيّنة المجانية
            </button>
          </form>
          <p id="lead-status" class="mt-3 text-sm text-ink-300" aria-live="polite"></p>
          <p class="mt-2 text-xs text-ink-400">نحترم خصوصيتك. لا spam. أزل اشتراكك بنقرة واحدة في أي وقت.</p>
        </div>
        <div class="md:col-span-5">
          <div class="relative mx-auto max-w-xs">
            <div class="absolute -inset-4 bg-gradient-to-br from-brand-500/40 to-accent-500/30 blur-2xl rounded-3xl"></div>
            <div class="relative aspect-[3/4] rounded-2xl border border-white/10 bg-gradient-to-br from-ink-700 to-ink-900 p-5 shadow-xl">
              <div class="text-[10px] tracking-[0.3em] text-brand-300 font-bold uppercase">FREE · CHECKLIST</div>
              <h3 class="mt-1 text-xl font-black text-ink-50 leading-snug">٧ خدمات AI<br/>للمستقل العربي</h3>
              <div class="mt-3 h-px w-12 bg-brand-400"></div>
              <p class="mt-3 text-sm text-ink-200 leading-relaxed">قائمة مراجعة عملية. ٦ صفحات. PDF.</p>
              <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between text-[10px] text-ink-400">
                <span>EDITION 2026</span>
                <span>{site.shortName}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(() => {
  const form = document.getElementById("lead-form");
  const status = document.getElementById("lead-status");
  if (!form || !status) return;
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const email = String(data.get("email") || "").trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      status.textContent = "أدخل بريداً إلكترونياً صحيحاً.";
      status.style.color = "#fca5a5";
      return;
    }
    status.textContent = "جارٍ الإرسال…";
    status.style.color = "#a9aebd";

    // Locally persist for the publisher to import into their ESP later.
    try {
      const list = JSON.parse(localStorage.getItem("mostakil:leads") || "[]");
      list.push({ email, ts: new Date().toISOString(), src: location.pathname });
      localStorage.setItem("mostakil:leads", JSON.stringify(list));
    } catch (_) { /* ignore */ }

    // Optional: POST to a configured endpoint (Brevo / Mailchimp / Buttondown / Resend / Cloudflare Worker).
    const endpoint = (window).__LEAD_ENDPOINT__ || "";
    if (endpoint) {
      try {
        await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, source: location.href }),
        });
      } catch (_) { /* swallow — we still deliver the file */ }
    }

    if (window.fbq) try { window.fbq("track", "Lead"); } catch (_) {}
    if (window.ttq) try { window.ttq.track("SubmitForm"); } catch (_) {}
    if (window.gtag) try { window.gtag("event", "generate_lead"); } catch (_) {}

    status.innerHTML = 'تم! اضغط لتحميل العيّنة الآن: ' +
      '<a class="text-brand-300 underline font-bold" href="/thanks.html">انتقل إلى صفحة التحميل ←</a>';
    status.style.color = "#86efac";
    window.location.href = "/thanks.html?email=" + encodeURIComponent(email);
  });
})();
</script>
